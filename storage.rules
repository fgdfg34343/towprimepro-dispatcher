rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Разрешаем любому аутентифицированному пользователю читать и писать
    // Для разработки - упрощенные правила
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
